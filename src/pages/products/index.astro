---
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import rfHunter from "@/assets/rf-hunter.png";
import usbDByte from "@/assets/1.png";

const products = [
  {
    name: "RF Hunter",
    href: "/products/rf-hunter",
    image: rfHunter,
    price: "From Rs. 1,999.00",
    text: "Standalone wireless security research platform for studying 2.4 GHz behavior under authorized test conditions.",
  },
  {
    name: "USB D-Byte",
    href: "/products/usb-d-byte",
    image: usbDByte,
    price: "From Rs. 699.00",
    text: "RP2040 USB development board for HID automation, payload testing, and embedded prototyping.",
  },
];
---

<Layout title="Products">
  <Container class="border-t border-neutral-200 py-14">
    <section>
      <p class="text-sm font-medium uppercase tracking-wide text-neutral-500">Products</p>
      <h1 class="mt-3 max-w-3xl text-5xl font-semibold tracking-tight text-neutral-950">
        Minimal devices for research, automation, and embedded work.
      </h1>
    </section>

    <section class="mt-10 grid gap-6 md:grid-cols-2">
      {
        products.map((product) => (
          <a href={product.href} class="group block border border-neutral-200 p-4 transition hover:border-neutral-950">
            <div class="bg-neutral-100">
              <Image
                src={product.image}
                alt={product.name}
                width={820}
                height={615}
                class="aspect-[4/3] w-full object-contain transition duration-300 group-hover:scale-[1.01]"
              />
            </div>
            <div class="mt-5 flex items-start justify-between gap-4">
              <div>
                <h2 class="text-2xl font-semibold">{product.name}</h2>
                <p class="mt-2 leading-7 text-neutral-600">{product.text}</p>
              </div>
              <p class="shrink-0 text-sm font-medium text-neutral-950">{product.price}</p>
            </div>
          </a>
        ))
      }
    </section>
  </Container>
</Layout>
