---
import Contactform from "@/components/contactform.astro";
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Contact">
  <Container class="border-t border-neutral-200 py-14">
    <div class="mx-auto grid max-w-5xl gap-10 md:grid-cols-2">
      <div>
        <p class="text-sm font-medium uppercase tracking-wide text-neutral-500">Contact</p>
        <h1 class="mt-3 text-5xl font-semibold tracking-tight text-neutral-950">
          Let's build useful hardware.
        </h1>
        <p class="mt-5 text-lg leading-8 text-neutral-600">
          Use the form for product questions, custom device enquiries, educational tools, and embedded systems work.
        </p>
        <div class="mt-8 space-y-3 text-neutral-700">
          <p><span class="font-medium text-neutral-950">Email:</span> <a href="mailto:rdhrobotics@hotmail.com" class="hover:underline">rdhrobotics@hotmail.com</a></p>
          <p><span class="font-medium text-neutral-950">Docs:</span> <a href="https://docs.rdhrobotics.in" class="hover:underline">docs.rdhrobotics.in</a></p>
        </div>
      </div>
      <Contactform />
    </div>
  </Container>
</Layout>
