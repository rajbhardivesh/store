---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Products">
  <main class="mx-auto max-w-3xl px-5 py-20 text-center">
    <h1 class="text-4xl font-semibold tracking-tight">Products have moved.</h1>
    <p class="mt-4 text-neutral-600">Explore RDH Robotics hardware on the products page.</p>
    <a
      href="/products"
      class="mt-8 inline-flex rounded-sm bg-neutral-950 px-6 py-3 font-medium text-white transition hover:bg-neutral-800">
      View Products
    </a>
  </main>
</Layout>
