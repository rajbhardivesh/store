---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout title="Blog">
  <Container class="border-t border-neutral-200 py-14">
    <main class="mx-auto max-w-4xl">
      <p class="text-sm font-medium uppercase tracking-wide text-neutral-500">Blog</p>
      <h1 class="mt-3 text-5xl font-semibold tracking-tight text-neutral-950">
        RDH Robotics Blog
      </h1>
      <div class="mt-10 border border-neutral-200 p-8">
        <p class="text-lg font-medium text-neutral-950">Demo page</p>
        <p class="mt-3 leading-7 text-neutral-600">
          Product notes, build logs, security research writeups, and documentation updates will appear here soon.
        </p>
      </div>
    </main>
  </Container>
</Layout>
